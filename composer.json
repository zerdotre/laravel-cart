{
    "name": "zerdotre/laravel-cart",
    "description": "Laravel Cart",
    "homepage": "https://github.com/zerdotre/laravel-cart",
    "support": {
        "source": "https://github.com/zerdotre/laravel-cart"
    },
    "keywords": [
        "laravel",
        "shopping cart",
        "cart"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Darryl Fernandez",
            "email": "engrdarrylfernandez@gmail.com"
        },
        {
            "name": "zerdotre",
            "email": "zerdotre@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0",
        "illuminate/translation": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^12.0",
        "symfony/var-dumper": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Darryldecode\\": "src/Darryldecode"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Darryldecode\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Darryldecode\\Cart\\CartServiceProvider"
            ],
            "aliases": {
                "Cart": "Darryldecode\\Cart\\Facades\\CartFacade"
            }
        }
    }
}